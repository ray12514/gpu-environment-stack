# Spack-generated files (do not commit the live install tree)
spack/opt/
spack/.spack-env/
spack/.spack-db/
*.spack
*.spec.lock

# Build artifacts
build-stage/
__pycache__/
*.pyc
*.pyo

# Editor / OS
.DS_Store
.vscode/
*.swp
*.swo

# Operator config — never commit paths or credentials
config/system.env

# Generated by bootstrap.sh from spack.yaml.template — not committed
spack/envs/*/spack.yaml

# Generated by detect-externals.sh at runtime — not committed
spack/systems/*/

detect-externals.log
