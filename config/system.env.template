# config/system.env.template
#
# Copy this file to config/system.env and fill in all <PLACEHOLDER> values.
# bootstrap.sh will fail early if SYSTEM_NAME or SITE_STACK_ROOT still contain '<'.
#
# config/system.env is in .gitignore — never commit it.

# ---------------------------------------------------------------------------
# Required: fill in before running bootstrap.sh
# ---------------------------------------------------------------------------

# Absolute path to the shared filesystem location where the stack is installed.
# Must be writable by the operator and readable by all users.
export SITE_STACK_ROOT="<SITE_STACK_ROOT>"

# Short name for this system — no spaces, e.g. "crusher", "polaris", "frontier01".
# Used as a directory name under spack/systems/ and in evidence paths.
export SYSTEM_NAME="<SYSTEM_NAME>"

# Spack version. "latest" (default) resolves to the current stable release at bootstrap
# time via the GitHub API. Pin to a specific tag (e.g. v0.23.1) for reproducibility.
export SPACK_VERSION="latest"

# ---------------------------------------------------------------------------
# Derived paths — do not change unless you know what you are doing
# ---------------------------------------------------------------------------

export REPO_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
export SPACK_ROOT="${SITE_STACK_ROOT}/spack/${SPACK_VERSION}"

# ---------------------------------------------------------------------------
# Release
# ---------------------------------------------------------------------------

export RELEASE="2026.06"
export SPACK_ENV_NAME="cray-amd-dev"
export SPACK_ENV_PATH="${REPO_ROOT}/spack/envs/${SPACK_ENV_NAME}"

# ---------------------------------------------------------------------------
# System hardware — adjust if your system differs
# ---------------------------------------------------------------------------

export PLATFORM_CLASS="cray-amd"
export GPU_VENDOR="amd"
export AMDGPU_TARGET="gfx90a"        # MI250X target
export GPUS_PER_NODE="8"             # GCDs per node (MI250X: 4 dies × 2 GCDs)
export CPUS_PER_NODE="64"

# ---------------------------------------------------------------------------
# Validation
# ---------------------------------------------------------------------------

# Number of nodes to allocate for T1 OSU and ML smoke tests.
export VALIDATE_NODE_COUNT="2"

# PBS resource directives are in config/pbs_resources.template — edit that file
# for your system's GPU allocation syntax before running validate.sh.

# ---------------------------------------------------------------------------
# Evidence
# ---------------------------------------------------------------------------

export EVIDENCE_DIR="${SITE_STACK_ROOT}/evidence/${RELEASE}/${SYSTEM_NAME}"
