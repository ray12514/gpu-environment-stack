#!/bin/bash
#PBS -N validate-t1-osu
#PBS -l select={{ validate_node_count }}:ncpus={{ cpus_per_node }}:ngpus={{ gpus_per_node }}
#PBS -q {{ pbs_queue }}
#PBS -l walltime=00:20:00
#PBS -o {{ validate_evidence_dir }}/t1_osu_job.log
#PBS -e {{ validate_evidence_dir }}/t1_osu_job.err
#PBS -j oe

source /etc/profile.d/modules.sh 2>/dev/null || true
module load {{ front_door_module }}

# GPU-buffer bandwidth: both processes use device (D) buffers
gpu-run \
    -n 2 \
    --ppn 1 \
    {{ osu_bw_bin }} \
    -d rocm D D \
    -m 1:67108864 \
    | tee {{ validate_evidence_dir }}/t1_osu_bw.txt

# GPU-buffer latency
gpu-run \
    -n 2 \
    --ppn 1 \
    {{ osu_lat_bin }} \
    -d rocm D D \
    -m 1:4096 \
    | tee {{ validate_evidence_dir }}/t1_osu_latency.txt
