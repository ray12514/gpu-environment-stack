#!/bin/bash
#PBS -N validate-ml-smoke
#PBS -l select={{ validate_node_count }}:ncpus={{ cpus_per_node }}:ngpus={{ gpus_per_node }}
#PBS -q {{ pbs_queue }}
#PBS -l walltime=00:30:00
#PBS -o {{ validate_evidence_dir }}/ml_smoke_job.log
#PBS -e {{ validate_evidence_dir }}/ml_smoke_job.err
#PBS -j oe

source /etc/profile.d/modules.sh 2>/dev/null || true
module load {{ front_door_module }}

# Determine master address from PBS_NODEFILE
MASTER_ADDR=$(head -1 "$PBS_NODEFILE")
MASTER_PORT=29500
NNODES={{ validate_node_count }}
NPROC_PER_NODE={{ gpus_per_node }}

gpu-run \
    -n $(( NNODES * NPROC_PER_NODE )) \
    --ppn {{ gpus_per_node }} \
    torchrun \
        --nproc_per_node={{ gpus_per_node }} \
        --nnodes=${NNODES} \
        --rdzv_backend=c10d \
        --rdzv_endpoint=${MASTER_ADDR}:${MASTER_PORT} \
        {{ site_stack_root }}/wrappers/libexec/benchmark_ddp.py \
            --model llama-1b \
            --steps 50 \
    | tee {{ validate_evidence_dir }}/ml_smoke.txt

# Extract final tokens/sec for the evidence bundle
grep "^RESULT tokens/sec=" {{ validate_evidence_dir }}/ml_smoke.txt \
    | tail -1 \
    | sed 's/RESULT tokens\/sec=//' \
    > {{ validate_evidence_dir }}/ml_tokens_per_sec.txt
