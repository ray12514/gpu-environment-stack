schema_version: "1.0"
release: "{{ release }}"
system: "{{ inventory_hostname }}"
platform_class: "{{ platform_class }}"
validation_layer: L1
executed_at: "{{ ansible_date_time.iso8601 }}"
owner: "{{ ansible_user_id }}"

results:

  preflight:
    capability: environment
    result: "{{ 'pass' if preflight_stack_info.rc == 0 else 'fail' }}"
    command: "gpu-stack-info"

  t0_gpu_visible:
    capability: T0
    result: "{{ 'pass' if t0_submit.rc == 0 else 'fail' }}"
    command: "rocm-smi --showproductname"
    artifacts:
      - "{{ validate_evidence_dir }}/t0_rocm_smi.txt"

  t1_gpu_mpi:
    capability: T1
    result: "{{ 'pass' if t1_submit.rc == 0 else 'fail' }}"
    benchmark_family: osu-micro-benchmarks
    workload_class: point-to-point GPU-buffer
    node_count: {{ validate_node_count }}
    gpu_count: {{ validate_node_count | int * gpus_per_node | int }}
    metrics:
      osu_bw_peak_mbs: {{ t1_peak_bw.stdout | float }}
    artifacts:
      - "{{ validate_evidence_dir }}/t1_osu_bw.txt"
      - "{{ validate_evidence_dir }}/t1_osu_latency.txt"

  ml_smoke:
    capability: T1
    result: "{{ 'pass' if ml_submit.rc == 0 else 'fail' }}"
    benchmark_family: pytorch-ddp
    workload_class: distributed training smoke
    node_count: {{ validate_node_count }}
    gpu_count: {{ validate_node_count | int * gpus_per_node | int }}
    metrics:
      tokens_per_sec: {{ ml_result_raw.content | b64decode | trim | float }}
    artifacts:
      - "{{ validate_evidence_dir }}/ml_smoke.txt"
